# =============================================================================
# gcploc environment configuration
# =============================================================================
# Copy to .env and adjust as needed.
# All variables have sensible defaults hardcoded in docker-compose.yml,
# so this file is optional for default local dev usage.
# =============================================================================

# ── Shared GCP project identifier used by all emulators ───────────────────
# Pub/Sub and Cloud Tasks use this as the GCP project ID in resource names.
# e.g. projects/<GCPLOC_PROJECT_ID>/topics/my-topic
GCPLOC_PROJECT_ID=gcploc-local

# ── Cloud Tasks region (must match what apps are configured to use) ────────
GCPLOC_TASKS_LOCATION=us-central1

# ── Host ports published by emulator containers ────────────────────────────
# Change these if a local port is already in use.
GCPLOC_PUBSUB_HOST_PORT=8085
GCPLOC_GCS_HOST_PORT=4443
GCPLOC_CLOUDTASKS_HOST_PORT=8123
GCPLOC_FIRESTORE_HOST_PORT=8080
GCPLOC_SPANNER_GRPC_HOST_PORT=9010
GCPLOC_SPANNER_REST_HOST_PORT=9020
GCPLOC_BIGTABLE_HOST_PORT=8086
GCPLOC_SECRETMANAGER_HOST_PORT=4444

# ── Secret Manager image override (experimental) ───────────────────────────
# The default is a community-maintained fake. Swap if you prefer an alternative.
GCPLOC_SECRETMANAGER_IMAGE=nicholasgasior/gcp-secret-manager-fake:latest

# ── Control panel URL (gcploc start cp / gcploc doctor) ──────────────────
GCPLOC_CP_URL=http://localhost:5173

# ── Cloud Tasks queue names ────────────────────────────────────────────────
# Queues are created by emulator startup flags in docker-compose.yml.
GCPLOC_TASKS_QUEUE_PRIMARY=default
GCPLOC_TASKS_QUEUE_SECONDARY=ai

# ── Pub/Sub emulator host ──────────────────────────────────────────────────
# Applications set this in their own .env files.
PUBSUB_EMULATOR_HOST=pubsub:8085

# ── Fake GCS emulator host ─────────────────────────────────────────────────
# Applications set this in their own .env files.
STORAGE_EMULATOR_HOST=fakegcs:4443

# ── Cloud Tasks emulator host ──────────────────────────────────────────────
# Applications set this in their own .env files.
CLOUD_TASKS_EMULATOR_HOST=cloudtasks:8123
